openapi: 3.0.4
info:
  title: Posada
  description: API REST para gestión de huéspedes, habitaciones, reservas y pagos de un hotel
  version: 1.0.0
  contact:
    name: Guadalupe Trejo
    email: l22140776@queretaro.tecnm.mx

servers:
  - url: http://localhost:8081/api/v1
    description: Servidor de desarrollo

tags:
  - name: guests
    description: Gestión de huéspedes
  - name: rooms
    description: Gestión de habitaciones
  - name: reservations
    description: Gestión de reservas
  - name: payments
    description: Gestión de pagos

paths:

  /guests:
    post:
      summary: Crear huésped
      tags: [guests]
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Guest'
      responses:
        '201':
          description: Huésped creado
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GuestResponse'
        '400':
          $ref: '#/components/responses/BadRequest'

    get:
      summary: Obtener huéspedes
      tags: [guests]
      responses:
        '200':
          description: Lista de huéspedes
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/GuestResponse'

  /guests/{guestId}:
    get:
      summary: Obtener huésped por ID
      tags: [guests]
      parameters:
        - $ref: '#/components/parameters/GuestId'
      responses:
        '200':
          description: OK
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GuestResponse'
        '404':
          $ref: '#/components/responses/NotFound'

    put:
      summary: Actualizar huésped
      tags: [guests]
      parameters:
        - $ref: '#/components/parameters/GuestId'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Guest'
      responses:
        '200':
          description: Actualizado
        '400':
          $ref: '#/components/responses/BadRequest'

    delete:
      summary: Eliminar huésped
      tags: [guests]
      parameters:
        - $ref: '#/components/parameters/GuestId'
      responses:
        '204':
          description: Eliminado

components:

  parameters:
    GuestId:
      name: guestId
      in: path
      required: true
      schema:
        type: string

  responses:
    BadRequest:
      description: Datos inválidos
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ApiError'

    NotFound:
      description: Recurso no encontrado
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/ApiError'

  schemas:

    Guest:
      type: object
      required:
        - name
        - phone
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 100
          example: "Juan Perez"
        phone:
          type: string
          pattern: '^[0-9]{10}$'
          example: "4421234567"
        email:
          type: string
          format: email
          minLength: 5

    GuestResponse:
      allOf:
        - $ref: '#/components/schemas/Guest'
        - type: object
          required: [id]
          properties:
            id:
              type: string

    Room:
      type: object
      required:
        - number
        - type
        - price
      properties:
        number:
          type: integer
          minimum: 1
        type:
          type: string
          enum:
            - Sencilla
            - Doble
            - Doble con aire acondicionado
        price:
          type: number
          minimum: 0
        status:
          type: string
          enum:
            - Available
            - Occupied
            - Unavailable

    Reservation:
      type: object
      required:
        - guestId
        - roomId
        - checkIn
        - checkOut
      properties:
        guestId:
          type: string
          minLength: 1
        roomId:
          type: string
          minLength: 1
        checkIn:
          type: string
          format: date
        checkOut:
          type: string
          format: date

    Payment:
      type: object
      required:
        - reservationId
        - amount
        - method
        - date
      properties:
        reservationId:
          type: string
        amount:
          type: number
          minimum: 0
        method:
          type: string
          enum: [card, cash, transfer]
        date:
          type: string
          format: date

    ApiError:
      type: object
      required:
        - code
        - message
        - timestamp
      properties:
        code:
          type: string
        message:
          type: string
        timestamp:
          type: string
          format: date-time
